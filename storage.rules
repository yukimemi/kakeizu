rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Photos belong to a tree. Members can read; only owner/editor can write.
    match /trees/{treeId}/persons/{file=**} {
      function memberRoles() {
        return firestore.get(/databases/(default)/documents/trees/$(treeId)).data.memberRoles;
      }
      function memberIds() {
        return firestore.get(/databases/(default)/documents/trees/$(treeId)).data.memberIds;
      }
      allow read: if request.auth != null
        && firestore.exists(/databases/(default)/documents/trees/$(treeId))
        && request.auth.uid in memberIds();
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/trees/$(treeId))
        && memberRoles()[request.auth.uid] in ['owner', 'editor'];
    }
  }
}
