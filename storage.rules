rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /trees/{treeId}/persons/{file=**} {
      function memberRoles() {
        return firestore.get(/databases/(default)/documents/trees/$(treeId)).data.memberRoles;
      }
      function memberIds() {
        return firestore.get(/databases/(default)/documents/trees/$(treeId)).data.memberIds;
      }
      function accessConfig() {
        return firestore.get(/databases/(default)/documents/config/access).data;
      }
      function isAllowedEmail() {
        return request.auth != null
          && request.auth.token.email_verified == true
          && firestore.exists(/databases/(default)/documents/config/access)
          && (request.auth.token.email in accessConfig().get('allowedEmails', [])
              || request.auth.token.email in accessConfig().get('adminEmails', []));
      }
      allow read: if request.auth != null
        && firestore.exists(/databases/(default)/documents/trees/$(treeId))
        && request.auth.uid in memberIds();
      allow write: if isAllowedEmail()
        && firestore.exists(/databases/(default)/documents/trees/$(treeId))
        && memberRoles()[request.auth.uid] in ['owner', 'editor'];
    }
  }
}
