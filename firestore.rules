rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userEmail() {
      return request.auth.token.email;
    }
    function accessConfig() {
      return get(/databases/$(database)/documents/config/access).data;
    }
    function isAllowedEmail() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/config/access)
        && userEmail() in accessConfig().allowedEmails;
    }

    function treeData(treeId) {
      return get(/databases/$(database)/documents/trees/$(treeId)).data;
    }
    function treeExists(treeId) {
      return exists(/databases/$(database)/documents/trees/$(treeId));
    }
    function isMember(treeId) {
      return request.auth != null
        && treeExists(treeId)
        && request.auth.uid in treeData(treeId).memberIds;
    }
    function roleIn(treeId, allowed) {
      return request.auth != null
        && treeExists(treeId)
        && treeData(treeId).memberRoles[request.auth.uid] in allowed;
    }
    function canEdit(treeId) {
      return roleIn(treeId, ['owner', 'editor']);
    }
    function isOwner(treeId) {
      return roleIn(treeId, ['owner']);
    }
    // Self-claim: a signed-in user with a verified email can update a tree
    // they were invited to (their email is in invitedEmails). Used to add
    // themselves to memberIds and remove their email from invitedEmails.
    function isClaiming(treeId) {
      return request.auth != null
        && request.auth.token.email_verified == true
        && userEmail() in resource.data.invitedEmails
        && request.auth.uid in request.resource.data.memberIds
        && !(userEmail() in request.resource.data.get('invitedEmails', []));
    }

    // Access-list: any signed-in user can read so the app can decide what to
    // show; only allowed users can mutate (so invitations grow the list).
    match /config/access {
      allow read: if request.auth != null;
      allow write: if isAllowedEmail();
    }

    // Users: any signed-in user can read (lookup an email by uid for member
    // display). Only the owner of the doc can write to themselves.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // Members may rewrite their own identity cache (memberInfo) so display
    // names / emails stay current without involving the owner.
    function isSelfInfoUpdate(treeId) {
      return request.auth != null
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberInfo', 'updatedAt']);
    }

    match /trees/{treeId} {
      allow read: if request.auth != null
        && (request.auth.uid in resource.data.memberIds
            || (request.auth.token.email_verified == true
                && userEmail() in resource.data.get('invitedEmails', [])));
      allow create: if isAllowedEmail()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberRoles[request.auth.uid] == 'owner';
      allow update: if isOwner(treeId)
        || isClaiming(treeId)
        || isSelfInfoUpdate(treeId);
      allow delete: if isOwner(treeId);
    }

    match /persons/{personId} {
      allow read: if isMember(resource.data.treeId);
      allow create: if isAllowedEmail()
        && canEdit(request.resource.data.treeId);
      allow update, delete: if isAllowedEmail()
        && canEdit(resource.data.treeId);
    }

    match /relationships/{relId} {
      allow read: if isMember(resource.data.treeId);
      allow create: if isAllowedEmail()
        && canEdit(request.resource.data.treeId);
      allow update, delete: if isAllowedEmail()
        && canEdit(resource.data.treeId);
    }
  }
}
